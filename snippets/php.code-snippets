		"body": "php\ndeclare(strict_types=1);\n\nrequire_once __DIR__ . '/../bootstrap.php';\nrequire_admin();\n\nuse RedBeanPHP\\\\R;\n\n\\$id = (int) (\\$_GET['id'] ?? 0);\n\\$user = \\$id ? R::load('user', \\$id) : R::dispense('user');\n\nif (\\$id && !\\$user->id) {\n\thttp_response_code(404);\n\texit('User not found');\n}\n\n\\$errors = [];\n\nif (\\$_SERVER['REQUEST_METHOD'] === 'POST') {\n\tif (!csrf_check()) {\n\t\t\\$errors[] = 'Invalid form submission.';\n\t} else {\n\t\t\\$name  = trim((string) (\\$_POST['name'] ?? ''));\n\t\t\\$email = trim((string) (\\$_POST['email'] ?? ''));\n\t\t\\$role  = \\$_POST['role'] ?? 'user';\n\t\t\\$password = (string) (\\$_POST['password'] ?? '');\n\n\t\tif (\\$name === '')                            \\$errors[] = 'Name is required.';\n\t\tif (!filter_var(\\$email, FILTER_VALIDATE_EMAIL)) \\$errors[] = 'Invalid email.';\n\n\t\t\\$existing = R::findOne('user', 'email = ? AND id <> ?', [\\$email, (int) \\$user->id]);\n\t\tif (\\$existing) \\$errors[] = 'Email already in use.';\n\n\t\tif (!\\$errors) {\n\t\t\t\\$user->name  = \\$name;\n\t\t\t\\$user->email = \\$email;\n\t\t\t\\$user->role  = in_array(\\$role, ['user', 'editor', 'admin'], true) ? \\$role : 'user';\n\n\t\t\tif (\\$password !== '') {\n\t\t\t\tif (strlen(\\$password) < 8) {\n\t\t\t\t\t\\$errors[] = 'Password must be at least 8 characters.';\n\t\t\t\t} else {\n\t\t\t\t\t\\$user->password_hash = password_hash(\\$password, PASSWORD_DEFAULT);\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif (!\\$errors) {\n\t\t\t\tif (!\\$user->id) {\n\t\t\t\t\t\\$user->created_at = date('Y-m-d H:i:s');\n\t\t\t\t}\n\t\t\t\t\\$user->updated_at = date('Y-m-d H:i:s');\n\t\t\t\tR::store(\\$user);\n\t\t\t\tflash('success', 'User saved.');\n\t\t\t\tredirect('/admin/users.php');\n\t\t\t}\n\t\t}\n\t}\n}\n\n\\$page_title = \\$user->id ? 'Edit user' : 'New user';\n\\$active     = 'users';\n\nob_start();\n?>\n<div class=\"card border-0 shadow-sm\">\n\t<div class=\"card-body p-4\">\n\t\t<?php if (\\$errors): ?>\n\t\t\t