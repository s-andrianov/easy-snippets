	"php-helpers-all": {
		"description": "Php Helpers All",
		"scope": "php",
		"prefix": "php-helpers-all",
		"body": "php\n/**\n * Helpers — CSRF, flash, sanitize, redirect, current user.\n * Usage: require_once __DIR__ . '/helpers.php';\n */\n\ndeclare(strict_types=1);\n\nuse RedBeanPHP\\\\R;\n\n/** HTML-escape user input for safe output. */\nfunction e(?string \\$value): string {\n\treturn htmlspecialchars((string) \\$value, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');\n}\n\n/** Get CSRF token (creates one if missing). */\nfunction csrf_token(): string {\n\tif (empty(\\$_SESSION['csrf'])) {\n\t\t\\$_SESSION['csrf'] = bin2hex(random_bytes(32));\n\t}\n\treturn \\$_SESSION['csrf'];\n}\n\n/** Hidden CSRF input — print directly in <form>. */\nfunction csrf_field(): string {\n\treturn '<input type=\"hidden\" name=\"csrf\" value=\"' . e(csrf_token()) . '\">';\n}\n\n/** Verify CSRF token from POST. */\nfunction csrf_check(): bool {\n\t\\$token = \\$_POST['csrf'] ?? '';\n\treturn is_string(\\$token) && hash_equals(csrf_token(), \\$token);\n}\n\n/** Flash a message (type: success, danger, warning, info). */\nfunction flash(string \\$type, string \\$message): void {\n\t\\$_SESSION['flash'][] = ['type' => \\$type, 'message' => \\$message];\n}\n\n/** Render all flashes as BS5 alerts and clear them. */\nfunction render_flashes(): string {\n\tif (empty(\\$_SESSION['flash'])) return '';\n\t\\$html = '';\n\tforeach (\\$_SESSION['flash'] as \\$f) {\n\t\t\\$html .= '<div class=\"alert alert-' . e(\\$f['type']) . ' alert-dismissible fade show\" role=\"alert\">'\n\t\t\t. e(\\$f['message'])\n\t\t\t. '<button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\" aria-label=\"Close\"></button>'\n\t\t\t. '</div>';\n\t}\n\tunset(\\$_SESSION['flash']);\n\treturn \\$html;\n}\n\n/** Redirect and stop execution. */\nfunction redirect(string \\$url): never {\n\theader('Location: ' . \\$url);\n\texit;\n}\n\n/** Get currently logged-in user (RedBean bean) or null. */\nfunction current_user(): ?\\\\RedBeanPHP\\\\OODBBean {\n\tif (empty(\\$_SESSION['user_id'])) return null;\n\t\\$u = R::load('user', (int) \\$_SESSION['user_id']);\n\treturn \\$u->id ? \\$u : null;\n}\n\n/** Require auth or redirect to login. */\nfunction require_auth(string \\$loginUrl = '/login.php'): \\\\RedBeanPHP\\\\OODBBean {\n\t\\$u = current_user();\n\tif (!\\$u) {\n\t\tflash('warning', 'Please sign in to continue.');\n\t\tredirect(\\$loginUrl);\n\t}\n\treturn \\$u;\n}\n\n/** Require admin role or 403. */\nfunction require_admin(): \\\\RedBeanPHP\\\\OODBBean {\n\t\\$u = require_auth();\n\tif (\\$u->role !== 'admin') {\n\t\thttp_response_code(403);\n\t\techo 'Forbidden';\n\t\texit;\n\t}\n\treturn \\$u;\n}\n\n/** Old() — repopulate form fields after validation error. */\nfunction old(string \\$key, string \\$default = ''): string {\n\treturn e(\\$_SESSION['old'][\\$key] ?? \\$default);\n}\n$1\n$0"
	},
