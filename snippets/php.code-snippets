		"body": "php\ndeclare(strict_types=1);\n\nrequire_once __DIR__ . '/bootstrap.php';\n\nuse RedBeanPHP\\\\R;\n\n\\$token = (string) (\\$_GET['token'] ?? \\$_POST['token'] ?? '');\n\\$user  = \\$token ? R::findOne('user', 'reset_token = ?', [\\$token]) : null;\n\nif (!\\$user) {\n\thttp_response_code(400);\n\texit('Invalid or expired token.');\n}\n\n\\$errors = [];\n\nif (\\$_SERVER['REQUEST_METHOD'] === 'POST') {\n\tif (!csrf_check()) {\n\t\t\\$errors[] = 'Invalid form submission.';\n\t} else {\n\t\t\\$password = (string) (\\$_POST['password'] ?? '');\n\t\t\\$confirm  = (string) (\\$_POST['password_confirmation'] ?? '');\n\n\t\tif (strlen(\\$password) < 8) \\$errors[] = 'Password must be at least 8 characters.';\n\t\tif (\\$password !== \\$confirm) \\$errors[] = 'Passwords do not match.';\n\n\t\tif (!\\$errors) {\n\t\t\t\\$user->password_hash = password_hash(\\$password, PASSWORD_DEFAULT);\n\t\t\t\\$user->reset_token   = null;\n\t\t\t\\$user->reset_sent_at = null;\n\t\t\tR::store(\\$user);\n\n\t\t\tflash('success', 'Password updated. Please sign in.');\n\t\t\tredirect('${1:/login.php}');\n\t\t}\n\t}\n}\n?>\n<!doctype html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"utf-8\" />\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n\t<title>Reset password</title>\n\t<link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css\" rel=\"stylesheet\" />\n</head>\n<body class=\"bg-body-tertiary\">\n\t<section class=\"vh-100 d-flex align-items-center\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"row justify-content-center\">\n\t\t\t\t<div class=\"col-12 col-md-6 col-lg-4\">\n\t\t\t\t\t<div class=\"card border-0 shadow-sm\"><div class=\"card-body p-4 p-md-5\">\n\t\t\t\t\t\t<h1 class=\"h4 fw-bold text-center mb-3\">Set a new password</h1>\n\n\t\t\t\t\t\t<?php if (\\$errors): ?>\n\t\t\t\t\t\t\t<div class=\"alert alert-danger\"><ul class=\"mb-0 ps-3\"><?php foreach (\\$errors as \\$err): ?><li><?= e(\\$err) ?></li><?php endforeach; ?></ul></div>\n\t\t\t\t\t\t<?php endif; ?>\n\n\t\t\t\t\t\t<form method=\"post\">\n\t\t\t\t\t\t\t<?= csrf_field() ?>\n\t\t\t\t\t\t\t<input type=\"hidden\" name=\"token\" value=\"<?= e(\\$token) ?>\" />\n\t\t\t\t\t\t\t<div class=\"form-floating mb-3\">\n\t\t\t\t\t\t\t\t<input type=\"password\" class=\"form-control\" name=\"password\" id=\"rp_pass\" placeholder=\"New password\" minlength=\"8\" required />\n\t\t\t\t\t\t\t\t<label for=\"rp_pass\">New password</label>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"form-floating mb-3\">\n\t\t\t\t\t\t\t\t<input type=\"password\" class=\"form-control\" name=\"password_confirmation\" id=\"rp_conf\" placeholder=\"Confirm\" required />\n\t\t\t\t\t\t\t\t<label for=\"rp_conf\">Confirm password</label>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<button class=\"btn btn-primary w-100 py-2\">Update password</button>\n\t\t\t\t\t\t</form>\n\t\t\t\t\t</div></div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</section>\n</body>\n</html>\n$0"
