		"body": "php\n/**\n * Safe single-file upload helper.\n * Returns relative path on success, null on failure.\n */\nfunction save_upload(string \\$field, string \\$dir = 'uploads', array \\$allowed = ['jpg','jpeg','png','gif','webp','pdf']): ?string {\n\tif (empty(\\$_FILES[\\$field]) || \\$_FILES[\\$field]['error'] !== UPLOAD_ERR_OK) {\n\t\treturn null;\n\t}\n\n\t\\$file = \\$_FILES[\\$field];\n\t\\$ext  = strtolower(pathinfo(\\$file['name'], PATHINFO_EXTENSION));\n\n\tif (!in_array(\\$ext, \\$allowed, true)) return null;\n\tif (\\$file['size'] > 5 * 1024 * 1024)  return null;\n\n\t\\$absDir = __DIR__ . '/../' . \\$dir;\n\tif (!is_dir(\\$absDir)) mkdir(\\$absDir, 0755, true);\n\n\t\\$safeName = bin2hex(random_bytes(12)) . '.' . \\$ext;\n\t\\$dest     = \\$absDir . '/' . \\$safeName;\n\n\tif (!move_uploaded_file(\\$file['tmp_name'], \\$dest)) return null;\n\n\treturn '/' . \\$dir . '/' . \\$safeName;\n}\n\n// Usage:\n// \\$path = save_upload('avatar');\n// if (\\$path) \\$user->avatar = \\$path;\n$0"
